generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  supabaseId   String?       @unique @map("supabase_id")
  email        String        @unique
  name         String?
  avatarUrl    String?       @map("avatar_url")
  role         String?
  organization String?
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at")
  auditLogs    AuditLog[]
  comments     FileComment[]
  files        File[]
  folders      Folder[]
  sharedByMe   SharedFile[]  @relation("SharedBy")
  sharedWithMe SharedFile[]  @relation("SharedWith")
  starredFiles StarredFile[]

  @@map("users")
}

model Folder {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name      String
  userId    String   @map("user_id")
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at")
  files     File[]
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderTree")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_folders_user_id")
  @@index([parentId], map: "idx_folders_parent_id")
  @@map("folders")
}

model File {
  id            String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  filename      String
  filetype      String
  size          Int
  storagePath   String        @unique @map("storage_path")
  userId        String        @map("user_id")
  folderId      String?       @map("folder_id")
  tags          String[]      @default([])
  thumbnailPath String?       @map("thumbnail_path")
  deletedAt     DateTime?     @map("deleted_at")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at")
  comments      FileComment[]
  versions      FileVersion[]
  folder        Folder?       @relation(fields: [folderId], references: [id])
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares        ShareLink[]
  sharedWith    SharedFile[]
  starredBy     StarredFile[]

  @@index([userId], map: "idx_files_user_id")
  @@index([folderId], map: "idx_files_folder_id")
  @@index([deletedAt], map: "idx_files_deleted_at")
  @@map("files")
}

model FileVersion {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  fileId        String   @map("file_id")
  versionNumber Int      @map("version_number")
  storagePath   String   @map("storage_path")
  size          Int
  note          String?
  uploadedAt    DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  file          File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, versionNumber])
  @@index([fileId], map: "idx_file_versions_file_id")
  @@map("file_versions")
}

model ShareLink {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  fileId    String   @map("file_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([token], map: "idx_share_links_token")
  @@map("share_links")
}

model SharedFile {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  fileId       String   @map("file_id")
  sharedById   String   @map("shared_by_id")
  sharedWithId String   @map("shared_with_id")
  permission   String   @default("VIEWER")
  status       String   @default("PENDING")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  file         File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  sharedBy     User     @relation("SharedBy", fields: [sharedById], references: [id])
  sharedWith   User     @relation("SharedWith", fields: [sharedWithId], references: [id])

  @@unique([fileId, sharedWithId])
  @@index([sharedWithId], map: "idx_shared_files_with_id")
  @@map("shared_files")
}

model FileComment {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  fileId    String   @map("file_id")
  userId    String   @map("user_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([fileId], map: "idx_file_comments_file_id")
  @@map("file_comments")
}

model StarredFile {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  fileId    String   @map("file_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([fileId, userId])
  @@index([userId], map: "idx_starred_files_user_id")
  @@map("starred_files")
}

model AuditLog {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String   @map("user_id")
  action    String
  fileId    String?  @map("file_id")
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_audit_logs_user_id")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
}
